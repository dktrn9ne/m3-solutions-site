{
  "version": 2,
  "builds": [
    { "src": "chat.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.pdf", "use": "@vercel/static" },
    { "src": "*.png", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/chat", "dest": "/chat.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
